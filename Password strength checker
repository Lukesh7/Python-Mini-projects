#using while loop to acquire strong pw from user
while True:
    #user input
    password = input("Enter your Password: ")
    #assumes all requirements are false
    has_letter = False
    has_number = False
    has_special = False
    #checks
    for char in password:

        if char.isalpha():
            has_letter = True

        elif char.isdigit():
            has_number = True

        else:
            has_special = True
#using score system 
    score = 0

    if len(password) >= 8:
        score += 1
    if has_letter:
        score += 1
    if has_number:
        score += 1
    if has_special:
        score += 1

#based on score 
    if score <= 2:
        print("Weak Password - Try again\n")

    elif score == 3:
        print("Medium Password - Try again\n")

    else:
        print("Strong Password ")
        break #stops loop when the pw is strong
