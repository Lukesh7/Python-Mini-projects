#password strength checker
password= input("Enter your PassWord :")   
#asumes there's none
has_letter = False
has_number = False
has_special = False

#to check whether the pw has these
for char in password:
    
    if char.isalpha():
        has_letter = True
        
    elif char.isdigit():
        has_number = True
        
    else:
        has_special = True

#using score for rating the pw                
score = 0

if len(password) >= 8:
    score += 1
    
if has_letter:
    score += 1
    
if has_number:
    score += 1
    
if has_special:
    score += 1
    
#now based on score we can say 
if score <=2:
    print("The PassWord  is Weak")
    
    
elif score == 3:
    print("The PassWord's strength is Medium") 
     
else:
    print("The Password is Strong")              
 
